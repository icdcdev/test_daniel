{
  "compilerOptions": {
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "preserveConstEnums": true,
    "sourceMap": true,
    "allowJs": true,
    "target": "ES2020",
    "outDir": ".build",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["es2015"],
    "types": ["node"],
    "rootDir": "./",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}